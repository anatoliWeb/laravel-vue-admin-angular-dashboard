
############################################################
# 🧠 Application Core
############################################################

APP_NAME=Laravel
APP_ENV=local
APP_KEY=                    # Generated via: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost

############################################################
# 🌍 Localization
############################################################

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

############################################################
# 🛠 Maintenance Mode
############################################################

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

############################################################
# 🔐 Security
############################################################

BCRYPT_ROUNDS=12

############################################################
# 📜 Logging
############################################################

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

############################################################
# 🗄 Database
############################################################

# Docker example:
# DB_HOST=mysql
# Local example:
# DB_HOST=127.0.0.1

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=saas
DB_USERNAME=saas
DB_PASSWORD=secret

############################################################
# 🍪 Sessions
############################################################

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

############################################################
# 📡 Broadcasting / Queue / Filesystem
############################################################

BROADCAST_DRIVER=reverb
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
HORIZON_NAME=saas-horizon
HORIZON_PATH=horizon
# Optional: if using custom subdomain for Horizon dashboard
HORIZON_DOMAIN=

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080
SANCTUM_TOKEN_EXPIRATION=1440

REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=6001
REVERB_APP_KEY=app-key
REVERB_APP_SECRET=app-secret
REVERB_APP_ID=app-id
REVERB_HOST=localhost
REVERB_PORT=6001
REVERB_SCHEME=http
REVERB_BROADCAST_HOST=reverb

############################################################
# ⚡ Cache
############################################################

CACHE_STORE=database
# Effective permissions cache TTL in seconds
RBAC_PERMISSIONS_CACHE_TTL=600
# CACHE_PREFIX=

############################################################
# 🚀 Redis
############################################################

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

############################################################
# 📧 Mail
############################################################

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

############################################################
# ☁️ AWS (optional)
############################################################

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

############################################################
# 🌐 CORS (Frontend Access)
############################################################

# Comma-separated list of allowed frontend origins
# Example:
# http://localhost:5173,https://app.myproject.com
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:5173

############################################################
# ⚛️ Frontend (Vite)
############################################################

VITE_APP_NAME="${APP_NAME}"

# Base API URL used by React frontend
VITE_API_BASE_URL=http://localhost:8080/api

# Vue Admin realtime (Reverb / Echo)
VITE_REVERB_APP_KEY=app-key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=6001
VITE_REVERB_SCHEME=http
VITE_REVERB_FORCE_TLS=false
